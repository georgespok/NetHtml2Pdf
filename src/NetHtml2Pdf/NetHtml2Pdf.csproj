<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="PdfRendering\**" />
    <EmbeddedResource Remove="PdfRendering\**" />
    <None Remove="PdfRendering\**" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Fonts\Inter-Regular.ttf" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Fonts\Inter-Regular.ttf">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="QuestPDF" Version="2025.7.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\NetHtml2Pdf.Parsing\NetHtml2Pdf.Parsing.csproj" />
  </ItemGroup>

</Project>
